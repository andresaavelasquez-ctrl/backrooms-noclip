{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://nocliponline.com/schemas/brmod-manifest-v1.json",
  "title": "Backrooms No-Clip Offline Mod Manifest",
  "type": "object",
  "required": ["formatVersion", "id", "name", "content"],
  "properties": {
    "formatVersion": { "const": 1 },
    "id": { "type": "string", "pattern": "^[A-Za-z0-9][A-Za-z0-9._-]{2,63}$" },
    "name": { "type": "string", "minLength": 1, "maxLength": 80 },
    "version": { "type": "string", "default": "1.0.0" },
    "author": { "type": "string", "maxLength": 80 },
    "description": { "type": "string", "maxLength": 500 },
    "content": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["id", "type", "model"],
        "properties": {
          "id": { "type": "string", "minLength": 1, "maxLength": 64 },
          "type": { "enum": ["prop", "decoration", "light_fixture", "item", "structure", "character", "entity"] },
          "model": { "type": "string" },
          "scale": { "type": "number", "exclusiveMinimum": 0, "maximum": 64 },
          "collision": { "type": "object" },
          "interaction": { "type": "object" },
          "spawn": {
            "type": "object",
            "properties": {
              "enabled": { "type": "boolean" },
              "levels": { "type": "array", "items": { "type": "string" } },
              "weight": { "type": "number", "minimum": 0, "maximum": 1 },
              "count": { "type": "array", "prefixItems": [{ "type": "integer", "minimum": 0 }, { "type": "integer", "minimum": 0 }], "minItems": 2, "maxItems": 2 }
            }
          }
        }
      }
    }
  }
}
